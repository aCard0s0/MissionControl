# Tailscale auth key — mint one in the admin console:
#   https://login.tailscale.com/admin → Settings → Keys → Generate auth key
# Recommended: Reusable, and tagged (e.g. tag:server) so the node never has
# key expiry and ACLs can target it. Keep this file out of git (.env is local).
TS_AUTHKEY=tskey-auth-…
